rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /stories/{fileName} {
      allow read: if true;
      allow write: if true;
    }

    match /messages/{fileName} {
      allow read: if true;
      allow write: if true;
    }

    match /audio/{fileName} {
      allow read: if true;
      allow write: if true;
    }

    match /profiles/{fileName} {
      allow read: if true;
      allow write: if true;
    }
  }
}
