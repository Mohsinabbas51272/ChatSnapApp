rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /secretConversations/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /friendRequests/{requestId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromId;
      allow update: if request.auth != null && request.auth.uid == resource.data.toId;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
    }

    match /friends/{friendId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.uids;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.uids;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid in resource.data.uids;
    }

    match /typing/{conversationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
